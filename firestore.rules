rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Utilisateurs : chacun peut lire/écrire son propre document, admin peut tout lire/écrire
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Vinyles de l'utilisateur
      match /vinyls/{vinylId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      // Snapshots de sauvegarde
      match /snapshots/{snapshotId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }

    // Config (clé API Anthropic, etc.) : lecture pour connectés, écriture admin uniquement
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
